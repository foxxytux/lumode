#!/usr/bin/env python3
"""Lumode - Lumo-powered coding agent launcher."""

import sys
from pathlib import Path

# Add current directory to path to import CLI modules
script_dir = Path(__file__).parent.absolute()
sys.path.insert(0, str(script_dir))

def main():
    try:
        from lumode_agent import main as agent_main
        agent_main()
        return
    except ImportError as e:
        if "lumode_agent" not in str(e):
            raise

    # Fallback for older checkouts where the agent module is missing.
    try:
        from lumo_secure_cli import main as secure_main
        secure_main()
    except ImportError as e:
        if "gnupg" in str(e) or "cryptography" in str(e):
            print("Note: Running without encryption support", file=sys.stderr)
            from lumo_cli import main as basic_main
            basic_main()
        else:
            raise

if __name__ == "__main__":
    main()
